rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // Rate-limit helper: max 1 lead creation per 10 seconds per IP-session.
    // Firestore doesn't have native rate-limiting, so we validate required
    // fields and enforce email format + size limits to deter spam.
    // ─────────────────────────────────────────────────────────────────────────

    // Leads collection - write from client, read only with auth
    match /leads/{leadId} {
      // Allow create with field validation to prevent spam/abuse
      allow create: if request.resource.data.keys().hasAll(['email', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 5
                    && request.resource.data.email.size() < 255
                    && request.resource.data.email.matches('.*@.*[.].*')
                    && request.resource.data.source is string
                    && request.resource.data.source.size() < 100
                    && (!('name' in request.resource.data) || request.resource.data.name.size() < 200)
                    && request.resource.data.keys().size() < 20;
      // Allow update only if email unchanged and only safe fields modified
      allow update: if request.resource.data.email == resource.data.email
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['score', 'engagements', 'status', 'productInterests', 'tags', 'updatedAt', 'name', 'company']);
      // Read requires authentication (admin only)
      allow read: if request.auth != null;
      // Delete requires authentication (admin only)
      allow delete: if request.auth != null;

      // Engagements subcollection
      match /engagements/{engagementId} {
        allow create: if request.resource.data.keys().hasAll(['type'])
                      && request.resource.data.type is string
                      && request.resource.data.keys().size() < 15;
        allow read: if request.auth != null;
      }
    }

    // ARIA conversations - write from authenticated or session-tracked users
    match /ariaConversations/{conversationId} {
      allow create: if request.resource.data.keys().hasAll(['sessionId'])
                    && request.resource.data.sessionId is string
                    && request.resource.data.sessionId.size() > 5
                    && request.resource.data.sessionId.size() < 100
                    && request.resource.data.keys().size() < 20;
      allow update: if resource.data.sessionId == request.resource.data.sessionId
                    && request.resource.data.keys().size() < 20;
      allow read: if request.auth != null;
    }

    // Content upgrades - read only
    match /contentUpgrades/{upgradeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // AI News & Product Aggregation Collections
    // ─────────────────────────────────────────────────────────────────────────

    // Dynamic blog posts - public read, Cloud Functions write
    match /blogPosts/{postId} {
      allow read: if true;
      // Allow client to increment viewCount only
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['viewCount', 'updatedAt']);
      // Full write requires auth (Cloud Functions use admin SDK)
      allow create, delete: if request.auth != null;
    }

    // AI Products directory - public read, limited client update
    match /aiProducts/{productId} {
      allow read: if true;
      // Allow client to increment clickCount only
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['clickCount', 'updatedAt']);
      allow create, delete: if request.auth != null;
    }

    // Affiliate click tracking - client write, admin read
    match /affiliateClicks/{clickId} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // News sources - admin only (configured via console or Cloud Functions)
    match /newsSources/{sourceId} {
      allow read, write: if request.auth != null;
    }

    // Processed articles - admin only (tracking which articles were processed)
    match /processedArticles/{articleId} {
      allow read, write: if request.auth != null;
    }

    // Purchases — written exclusively by Stripe webhook (admin SDK)
    // No client-side access: prevents forgery and protects PII
    match /purchases/{sessionId} {
      allow read, write: if false;
    }
  }
}
