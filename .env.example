# Google Analytics
VITE_GA_ID=G-XXXXXXXXXX

# Firebase — get from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# EmailJS — contact form (get from emailjs.com)
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Anthropic Claude API — ARIA chatbot (stored in Firebase Secret Manager, NOT here)
# firebase functions:secrets:set ANTHROPIC_API_KEY
# VITE_ANTHROPIC_API_KEY is intentionally removed — key is server-side only

# Resend Email Service — stored in Firebase Secret Manager, NOT here
# firebase functions:secrets:set RESEND_API_KEY
# VITE_RESEND_API_KEY is intentionally removed — key is server-side only

# Stripe — payment processing (get from https://dashboard.stripe.com/apikeys)
# Publishable key goes here. Secret key + webhook secret go in Firebase secrets:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Sentry — error tracking (get DSN from https://sentry.io → Project Settings → Client Keys)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Ollama (optional — only if self-hosting a local AI model)
VITE_OLLAMA_HOST=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2
VITE_OLLAMA_API_KEY=your_ollama_api_key