{
  "name": "ndn-analytics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "node server.js",
    "build": "tsc -b && vite build",
    "build:ssr": "tsc -b && vite build && vite build --ssr src/entry-ssr.tsx --outDir dist/ssr && node scripts/postbuild.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "optimize:images": "node scripts/optimize-images.cjs",
    "generate:critical": "node scripts/generate-critical.cjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@sentry/react": "^10.48.0",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "critical": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "globals": "^17.4.0",
    "jsdom": "29.0.1",
    "playwright": "^1.59.1",
    "sharp": "^0.32.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
